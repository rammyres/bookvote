# Copie para .env e preencha antes de subir o container.

# Chave usada para assinar cookies e hashear IPs. Gere com:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
BOOKVOTE_SECRET_KEY=

# Cloudflare Turnstile (captcha gratuito). Se deixar em branco, o captcha
# fica desativado e a app roda (útil para testar localmente, não recomendado
# em produção). Crie as chaves em https://dash.cloudflare.com/ > Turnstile.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Exige HTTPS para o cookie de identificação do votante (deixe "true" em produção).
BOOKVOTE_COOKIE_SECURE=true

# Quantas "identidades" de votante distintas uma mesma rede/IP pode criar por enquete.
BOOKVOTE_MAX_VOTERS_PER_IP=6

# Opcional: chave de API do Google Books (aumenta a cota de busca por IP).
# Sem essa chave a busca de livros (autocomplete na indicação) já funciona,
# só com uma cota pública mais baixa. Crie em https://console.cloud.google.com/
# (ative a "Books API" e gere uma API key).
GOOGLE_BOOKS_API_KEY=
